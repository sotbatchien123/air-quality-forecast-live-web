# Copy this file to .env and replace the placeholders. Never commit .env.
DB_HOST=your_tidb_cloud_host
DB_PORT=4000
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password
DB_DATABASE=air_quality_forecast

# TiDB Cloud should use VERIFY_IDENTITY. Use DISABLED only for a trusted local DB.
DB_SSL_MODE=VERIFY_IDENTITY
DB_SSL_CA=
DB_CONNECT_TIMEOUT=10

# When true, a configured database failure makes the hourly task retry.
# If no DB_* variables exist, collection remains CSV-only.
LIVE_DB_REQUIRED=true

# Prefer --tomtom-key-file for the existing PowerShell runner. This is an
# alternative for environments that inject secrets as variables.
TOMTOM_API_KEY=
